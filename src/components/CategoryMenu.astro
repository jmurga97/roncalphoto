---
// src/components/CategoryMenu.astro
import type { Category } from '../lib/types';

interface Props {
  /**
   * Lista de todas las categorías
   */
  categories: Category[];
  /**
   * Categoría actualmente activa
   */
  activeCategory?: Category;
}

const { categories, activeCategory } = Astro.props;

// Helper para obtener la URL de la primera sesión de una categoría
function getFirstSessionUrl(cat: Category): string {
  const firstSession = cat.sessions[0];
  return firstSession ? `/${cat.slug}/${firstSession.id}` : '#';
}
---

<nav class="category-menu" aria-label="Categorías">
  {activeCategory ? (
    <!-- Modo compacto: dropdown cuando hay sesión activa -->
    <details class="mb-6" open>
      <summary class="text-sm uppercase tracking-widest text-neutral-500 cursor-pointer hover:text-neutral-400 select-none list-none flex items-center gap-2">
        <svg class="w-4 h-4 transition-transform details-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
        {activeCategory.name}
      </summary>
      <ul class="mt-2 ml-6 space-y-1">
        {categories.map((cat) => (
          <li>
            <a
              href={getFirstSessionUrl(cat)}
              class:list={[
                'text-sm transition-colors block py-1',
                cat.slug === activeCategory.slug
                  ? 'text-white font-medium'
                  : 'text-neutral-500 hover:text-neutral-300',
              ]}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </details>
  ) : (
    <!-- Modo expandido: lista completa de categorías -->
    <div>
      <h2 class="text-sm uppercase tracking-widest text-neutral-500 mb-4">
        Categorías
      </h2>
      <ul class="space-y-4">
        {categories.map((category) => (
          <li>
            <span class="text-neutral-300 font-medium">{category.name}</span>
            {category.sessions.length > 0 ? (
              <ul class="ml-4 mt-2 space-y-1">
                {category.sessions.map((session) => (
                  <li>
                    <a
                      href={`/${category.slug}/${session.id}`}
                      class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors block py-1"
                    >
                      {session.title}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="ml-4 mt-1 text-xs text-neutral-600 italic">
                Sin sesiones
              </p>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
</nav>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details[open] summary svg {
    transform: rotate(90deg);
  }
</style>
