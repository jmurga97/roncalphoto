---
// src/components/Sidebar.astro
import type { Category, Session } from '../lib/types';
import CategoryMenu from './CategoryMenu.astro';
import SessionInfo from './SessionInfo.astro';
import SidebarToggle from './SidebarToggle.astro';

interface Props {
  /**
   * Lista de todas las categorías (para navegación)
   */
  categories: Category[];
  /**
   * Categoría activa (cuando hay una sesión seleccionada)
   */
  activeCategory?: Category;
  /**
   * Sesión activa (cuando se está viendo una sesión)
   */
  activeSession?: Session;
}

const { categories, activeCategory, activeSession } = Astro.props;
const isSessionView = activeCategory && activeSession;
---

<!-- Toggle button (posición fija en la derecha, independiente del sidebar) -->
<SidebarToggle />

<!-- Overlay para mobile -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Sidebar -->
<aside
  id="sidebar"
  class="fixed top-0 left-0 z-40 h-full w-full md:w-[25vw] bg-neutral-900 overflow-y-auto transform -translate-x-full transition-none"
  role="complementary"
  aria-label="Menú de navegación"
>
  <div class="p-8">
    <!-- Logo/Título -->
    <a
      href="/"
      class="text-2xl font-light tracking-wide mb-8 block hover:text-neutral-300 transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-500 rounded"
      id="sidebar-logo"
    >
      RoncalPhoto
    </a>

    <!-- Contenido del sidebar -->
    <div id="sidebar-content">
      {isSessionView ? (
        <div class="sidebar-session-view">
          <CategoryMenu categories={categories} activeCategory={activeCategory} />
          <SessionInfo category={activeCategory} session={activeSession} />
        </div>
      ) : (
        <div class="sidebar-nav-view">
          <CategoryMenu categories={categories} />
        </div>
      )}
    </div>
  </div>
</aside>

<script>
  import gsap from 'gsap';

  // Constantes
  const MOBILE_BREAKPOINT = 768;
  const STORAGE_KEY = 'sidebar-open';

  // Estado
  let isOpen = false;
  let isMobile = false;

  // Elementos DOM
  let sidebar: HTMLElement | null;
  let overlay: HTMLElement | null;
  let toggle: HTMLElement | null;
  let toggleIcon: SVGElement | null;
  let sidebarLogo: HTMLElement | null;
  let mainContent: HTMLElement | null;

  // Timeline de GSAP para animaciones
  let timeline: gsap.core.Timeline | null = null;

  function initElements(): void {
    sidebar = document.getElementById('sidebar');
    overlay = document.getElementById('sidebar-overlay');
    toggle = document.getElementById('sidebar-toggle');
    toggleIcon = document.getElementById('toggle-icon') as SVGElement | null;
    sidebarLogo = document.getElementById('sidebar-logo');
    mainContent = document.querySelector('main');
  }

  function getStoredState(): boolean {
    const stored = localStorage.getItem(STORAGE_KEY);
    return stored === 'true';
  }

  function saveState(open: boolean): void {
    localStorage.setItem(STORAGE_KEY, String(open));
  }

  function checkMobile(): boolean {
    return window.innerWidth < MOBILE_BREAKPOINT;
  }

  function updateToggleIcon(open: boolean): void {
    if (!toggleIcon) return;
    if (open) {
      toggleIcon.classList.add('is-open');
    } else {
      toggleIcon.classList.remove('is-open');
    }
  }

  function updateAriaAttributes(open: boolean): void {
    if (!toggle || !sidebar) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    sidebar.setAttribute('aria-hidden', String(!open));
  }

  function updateMainMargin(open: boolean, animate = true): void {
    if (!mainContent || isMobile) return;
    
    const marginLeft = open ? '25vw' : '0';
    
    if (animate) {
      gsap.to(mainContent, { 
        marginLeft, 
        duration: 0.4, 
        ease: 'power3.out' 
      });
    } else {
      gsap.set(mainContent, { marginLeft });
    }
  }

  function openSidebar(animate = true): void {
    if (!sidebar || !overlay) return;
    isOpen = true;

    // Kill any running animation
    timeline?.kill();

    if (animate) {
      timeline = gsap.timeline();
      
      if (isMobile) {
        // Mobile: fullscreen overlay + slide in
        overlay.classList.remove('pointer-events-none');
        timeline
          .to(overlay, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 0)
          .to(sidebar, { x: 0, duration: 0.4, ease: 'power3.out' }, 0);
      } else {
        // Desktop: slide in + adjust main content
        timeline.to(sidebar, { x: 0, duration: 0.4, ease: 'power3.out' });
        updateMainMargin(true, true);
      }
    } else {
      gsap.set(sidebar, { x: 0 });
      if (isMobile) {
        gsap.set(overlay, { opacity: 1 });
        overlay.classList.remove('pointer-events-none');
      } else {
        updateMainMargin(true, false);
      }
    }

    updateToggleIcon(true);
    updateAriaAttributes(true);
    
    // Focus management: focus first focusable element
    if (isMobile && sidebarLogo) {
      setTimeout(() => sidebarLogo?.focus(), 100);
    }
  }

  function closeSidebar(animate = true): void {
    if (!sidebar || !overlay) return;
    isOpen = false;

    // Kill any running animation
    timeline?.kill();

    const translateX = '-100%';

    if (animate) {
      timeline = gsap.timeline({
        onComplete: () => {
          overlay?.classList.add('pointer-events-none');
        }
      });
      
      timeline
        .to(sidebar, { x: translateX, duration: 0.3, ease: 'power3.in' }, 0)
        .to(overlay, { opacity: 0, duration: 0.3, ease: 'power2.in' }, 0);
      
      if (!isMobile) {
        updateMainMargin(false, true);
      }
    } else {
      gsap.set(sidebar, { x: translateX });
      gsap.set(overlay, { opacity: 0 });
      overlay.classList.add('pointer-events-none');
      if (!isMobile) {
        updateMainMargin(false, false);
      }
    }

    updateToggleIcon(false);
    updateAriaAttributes(false);
    
    // Focus management: return focus to toggle
    if (isMobile && toggle) {
      setTimeout(() => toggle?.focus(), 100);
    }
  }

  function toggleSidebar(): void {
    if (isOpen) {
      closeSidebar();
      saveState(false);
    } else {
      openSidebar();
      saveState(true);
    }
  }

  function handleResize(): void {
    const wasMobile = isMobile;
    isMobile = checkMobile();

    if (wasMobile !== isMobile) {
      // Viewport changed between mobile and desktop
      if (isMobile) {
        // Switched to mobile: close sidebar, reset main margin
        gsap.set(mainContent, { marginLeft: 0 });
        closeSidebar(false);
      } else {
        // Switched to desktop: restore saved state
        const savedState = getStoredState();
        if (savedState) {
          openSidebar(false);
        } else {
          closeSidebar(false);
        }
      }
    }
  }

  function handleKeydown(event: KeyboardEvent): void {
    // Close on Escape when sidebar is open
    if (event.key === 'Escape' && isOpen) {
      closeSidebar();
      saveState(false);
    }
  }

  function init(): void {
    initElements();
    if (!sidebar || !toggle) return;

    isMobile = checkMobile();

    // Set initial state
    if (isMobile) {
      // Mobile: always start closed
      closeSidebar(false);
    } else {
      // Desktop: restore saved state (default to open)
      const savedState = getStoredState();
      // Default to open on first visit
      if (localStorage.getItem(STORAGE_KEY) === null) {
        openSidebar(false);
        saveState(true);
      } else if (savedState) {
        openSidebar(false);
      } else {
        closeSidebar(false);
      }
    }

    // Event listeners
    toggle.addEventListener('click', toggleSidebar);
    overlay?.addEventListener('click', () => {
      closeSidebar();
      saveState(false);
    });
    window.addEventListener('resize', handleResize);
    document.addEventListener('keydown', handleKeydown);
  }

  // Initialize on page load (works with View Transitions)
  document.addEventListener('astro:page-load', init);
</script>
