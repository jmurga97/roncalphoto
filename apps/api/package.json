{
  "name": "@roncal/api",
  "description": "RoncalPhoto API - REST API for photography portfolio",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "CI=1 bun run db:migrate:local && wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "predeploy": "wrangler d1 migrations apply DB_RONCALPHOTO --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB_RONCALPHOTO --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB_RONCALPHOTO --remote",
    "db:generate": "drizzle-kit generate",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types",
    "check": "tsc"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@roncal/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.5",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.60.0"
  }
}
