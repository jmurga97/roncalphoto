# d1-roncalphoto API Configuration
# Copy this file to .env and fill in your values

# API URL - The deployed d1-roncalphoto Workers API
# For local development, use the local wrangler dev server
API_URL=http://localhost:8788

# API Key - Required for authentication with the API
# Get this from your Cloudflare Workers secrets or .dev.vars
API_KEY=your-api-key-here
