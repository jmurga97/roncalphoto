# RoncalPhoto frontend build-time overrides
# Copy this file to .env at the repo root only when you need to override the API origin.

# Canonical option for Vite apps.
# Omit it to use http://localhost:8787 in local browser sessions
# and https://api.roncalphoto.com everywhere else.
VITE_API_URL=http://localhost:8787

# Legacy alias kept temporarily for compatibility with older env files.
# API_URL=http://localhost:8787
