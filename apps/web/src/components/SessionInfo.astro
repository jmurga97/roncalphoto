---
// src/components/SessionInfo.astro
import type { Category, Session } from "@roncal/shared";

interface Props {
  /**
   * Categoría de la sesión
   */
  category: Category;
  /**
   * Sesión a mostrar
   */
  session: Session;
}

const { category, session } = Astro.props;
---

<div class="session-info">
  <!-- Lista de sesiones de la categoría -->
  {category.sessions.length > 1 && (
    <nav class="mb-6" aria-label="Sesiones de la categoría">
      <h3 class="text-xs uppercase tracking-widest text-neutral-600 mb-2">
        Sesiones
      </h3>
      <ul class="space-y-1">
        {category.sessions.map((sess) => (
          <li>
            <a
              href={`/${category.slug}/${sess.id}`}
              class:list={[
                'text-sm transition-colors block py-1',
                sess.id === session.id
                  ? 'text-white font-medium'
                  : 'text-neutral-500 hover:text-neutral-300',
              ]}
              aria-current={sess.id === session.id ? 'page' : undefined}
            >
              {sess.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <!-- Información de la sesión activa -->
  <div class="space-y-4 border-t border-neutral-800 pt-6">
    <h1 class="text-xl font-light tracking-wide">{session.title}</h1>
    <div
      class="text-neutral-400 text-sm leading-relaxed prose prose-invert prose-sm max-w-none"
      set:html={session.description}
    />
  </div>
</div>
