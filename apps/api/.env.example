ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:4321,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174
LOG_LEVEL=info
NODE_ENV=development

# The variables below are only required for local admin auth and OTP delivery.
BETTER_AUTH_SECRET=
EMAIL_WORKER_URL=http://localhost:8788
# Must match the email worker WORKER_API_KEY secret.
EMAIL_WORKER_API_KEY=
# Canonical admin origin. In local development auth also tolerates configured localhost origins.
PHOTOS_ADMIN_URL=http://localhost:5173

# D1 is configured through Wrangler bindings, not through .env files.
