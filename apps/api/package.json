{
  "name": "@roncal/api",
  "description": "RoncalPhoto API - REST API for photography portfolio",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run db:migrate:local && wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "predeploy": "wrangler d1 migrations apply DB_RONCALPHOTO --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB_RONCALPHOTO --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB_RONCALPHOTO --remote",
    "cf-typegen": "wrangler types",
    "check": "tsc"
  },
  "dependencies": {
    "@roncal/shared": "workspace:*",
    "hono": "^4.11.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.60.0"
  }
}
